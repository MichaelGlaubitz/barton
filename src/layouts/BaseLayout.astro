---
import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}

const {
	title,
	description = 'Mathechismus.de: kurze, wirksame Ideen für den Mathematikunterricht — mit Mini-Quiz.',
	ogImage,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const ogUrl = new URL(
	ogImage ?? `${import.meta.env.BASE_URL}og-image.png`,
	Astro.site ?? Astro.url,
).href;
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(() => {
				const stored = localStorage.getItem('theme');
				const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
				const theme = stored === 'light' || stored === 'dark' ? stored : prefersLight ? 'light' : 'dark';
				document.documentElement.setAttribute('data-theme', theme);

				const fsRaw = localStorage.getItem('fontScale');
				let scale = 100;
				if (fsRaw != null) {
					const n = parseInt(fsRaw, 10);
					if (Number.isFinite(n)) scale = Math.min(135, Math.max(80, n));
				}
				document.documentElement.style.fontSize = `${scale}%`;
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Mathechismus.de" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="de_DE" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogUrl} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="site-header__inner">
				<p class="site-title"><a href={import.meta.env.BASE_URL}>Mathechismus.de</a></p>
				<nav class="site-nav" aria-label="Hauptnavigation">
					<a href={import.meta.env.BASE_URL}>Alle Beiträge</a>
					<div class="site-tools" role="group" aria-label="Anzeige">
						<label class="font-scale-control">
							<span class="font-scale-control__hint" aria-hidden="true">A</span>
							<input
								type="range"
								class="font-scale-control__range"
								data-font-scale-range
								min="80"
								max="135"
								step="5"
								value="100"
								aria-valuemin="80"
								aria-valuemax="135"
								aria-valuenow="100"
								aria-label="Schriftgröße der Seite"
							/>
							<span class="font-scale-control__hint font-scale-control__hint--lg" aria-hidden="true">A</span>
							<span class="font-scale-control__value" data-font-scale-value aria-live="polite">100%</span>
						</label>
						<button type="button" class="theme-toggle" data-theme-toggle aria-label="Dunkles Farbschema aktivieren">
							<span aria-hidden="true" data-theme-toggle-icon>🌙</span>
						</button>
					</div>
				</nav>
			</div>
		</header>
		<main class="site-main">
			<slot />
			<footer class="site-footer">
				<p>
					<a href={`${import.meta.env.BASE_URL}gebote/`}>Die zehn Gebote</a>
					<span aria-hidden="true"> · </span>
					<a href={`${import.meta.env.BASE_URL}credo/`}>Bekenntnis &amp; Vaterunser</a>
					<span aria-hidden="true"> · </span>
					<a href={import.meta.env.BASE_URL}>Alle Beiträge</a>
				</p>
				<p class="site-footer__legal">
					<a href={`${import.meta.env.BASE_URL}impressum/`}>Impressum</a>
					<span aria-hidden="true"> · </span>
					<a href={`${import.meta.env.BASE_URL}datenschutz/`}>Datenschutz</a>
				</p>
			</footer>
		</main>
		<script is:inline>
			(() => {
				const readFontScale = () => {
					const fsRaw = localStorage.getItem('fontScale');
					if (fsRaw == null) return 100;
					const n = parseInt(fsRaw, 10);
					return Number.isFinite(n) ? Math.min(135, Math.max(80, n)) : 100;
				};

				const range = document.querySelector('[data-font-scale-range]');
				if (range instanceof HTMLInputElement) {
					const initial = readFontScale();
					range.value = String(initial);
					range.setAttribute('aria-valuenow', String(initial));
					const out = document.querySelector('[data-font-scale-value]');
					if (out) out.textContent = `${initial}%`;
					range.addEventListener('input', () => {
						const n = parseInt(range.value, 10);
						if (Number.isFinite(n)) {
							document.documentElement.style.fontSize = `${n}%`;
							localStorage.setItem('fontScale', String(n));
							range.setAttribute('aria-valuenow', String(n));
							if (out) out.textContent = `${n}%`;
						}
					});
				}

				const button = document.querySelector('[data-theme-toggle]');
				if (button instanceof HTMLButtonElement) {

				const icon = button.querySelector('[data-theme-toggle-icon]');
				const applyTheme = (theme) => {
					document.documentElement.setAttribute('data-theme', theme);
					localStorage.setItem('theme', theme);
					if (icon) icon.textContent = theme === 'light' ? '☀️' : '🌙';
					button.setAttribute(
						'aria-label',
						theme === 'light' ? 'Dunkles Farbschema aktivieren' : 'Helles Farbschema aktivieren'
					);
				};

				const current = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
				applyTheme(current);

				button.addEventListener('click', () => {
					const next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
					applyTheme(next);
				});
				}
			})();
		</script>
	</body>
</html>
