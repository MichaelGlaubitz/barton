---
import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}

const {
	title,
	description = 'Mathechismus.de: kurze, wirksame Ideen für den Mathematikunterricht — mit Mini-Quiz.',
	ogImage,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const ogUrl = new URL(
	ogImage ?? `${import.meta.env.BASE_URL}og-image.png`,
	Astro.site ?? Astro.url,
).href;
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(() => {
				const stored = localStorage.getItem('theme');
				const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
				const theme = stored === 'light' || stored === 'dark' ? stored : prefersLight ? 'light' : 'dark';
				document.documentElement.setAttribute('data-theme', theme);
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Mathechismus.de" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="de_DE" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogUrl} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="site-header__inner">
				<p class="site-title"><a href={import.meta.env.BASE_URL}>Mathechismus.de</a></p>
				<nav class="site-nav" aria-label="Hauptnavigation">
					<a href={import.meta.env.BASE_URL}>Alle Beiträge</a>
					<button type="button" class="theme-toggle" data-theme-toggle aria-label="Dunkles Farbschema aktivieren">
						<span aria-hidden="true" data-theme-toggle-icon>🌙</span>
					</button>
				</nav>
			</div>
		</header>
		<main class="site-main">
			<slot />
			<footer class="site-footer">
				<p>
					<a href={`${import.meta.env.BASE_URL}gebote/`}>Die zehn Gebote</a>
					<span aria-hidden="true"> · </span>
					<a href={`${import.meta.env.BASE_URL}credo/`}>Bekenntnis &amp; Vaterunser</a>
					<span aria-hidden="true"> · </span>
					<a href={import.meta.env.BASE_URL}>Alle Beiträge</a>
				</p>
			</footer>
		</main>
		<script is:inline>
			(() => {
				const button = document.querySelector('[data-theme-toggle]');
				if (!(button instanceof HTMLButtonElement)) return;

				const icon = button.querySelector('[data-theme-toggle-icon]');
				const apply = (theme) => {
					document.documentElement.setAttribute('data-theme', theme);
					localStorage.setItem('theme', theme);
					if (icon) icon.textContent = theme === 'light' ? '☀️' : '🌙';
					button.setAttribute(
						'aria-label',
						theme === 'light' ? 'Dunkles Farbschema aktivieren' : 'Helles Farbschema aktivieren'
					);
				};

				const current = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
				apply(current);

				button.addEventListener('click', () => {
					const next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
					apply(next);
				});
			})();
		</script>
	</body>
</html>
