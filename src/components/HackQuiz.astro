---
export interface QuizQuestion {
	question: string;
	options: string[];
	correctIndex: number;
	explanation: string;
}

interface Props {
	questions: QuizQuestion[];
	quizId: string;
}

const { questions, quizId } = Astro.props;
if (!questions?.length) return null;

const rootId = `hack-quiz-root-${quizId}`;
const questionsJson = JSON.stringify(questions);
---

<section
	class="quiz"
	aria-labelledby={`quiz-heading-${quizId}`}
	id={rootId}
	data-hack-quiz
	data-quiz-id={quizId}
	data-questions={questionsJson}
>
	<h2 id={`quiz-heading-${quizId}`}>Mini-Quiz</h2>
	<p class="quiz-intro">Wähle eine Antwort — Rückmeldung erscheint sofort.</p>
	{
		questions.map((q, qi) => (
			<div class="quiz-question" data-quiz-question={qi}>
				<p class="quiz-question__prompt">
					<span class="quiz-question__num">{String(qi + 1).padStart(2, '0')}</span>
					<span set:html={q.question} />
				</p>
				<div
					class="quiz-options"
					role="radiogroup"
					aria-labelledby={`q-${quizId}-${qi}-label`}
					data-quiz-options={`${quizId}-${qi}`}
				>
					<span id={`q-${quizId}-${qi}-label`} class="visually-hidden">
						Frage {qi + 1}
					</span>
					{q.options.map((opt, oi) => (
						<label class="quiz-option" data-option-index={oi}>
							<input type="radio" name={`q-${quizId}-${qi}`} value={oi} />
							<span class="quiz-option__bullet" aria-hidden="true" />
							<span class="quiz-option__text" set:html={opt} />
						</label>
					))}
				</div>
				<div class="quiz-feedback" data-feedback={`${quizId}-${qi}`} hidden />
				<div class="quiz-actions" data-actions={`${quizId}-${qi}`} hidden>
					<button type="button" class="btn btn--ghost" data-reset={`${quizId}-${qi}`}>
						Noch einmal
					</button>
				</div>
			</div>
		))
	}
</section>

<style is:global>
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>

<script>
	function initOne(root: HTMLElement) {
		const quizId = root.getAttribute('data-quiz-id');
		const questionsJson = root.getAttribute('data-questions');
		if (!quizId || !questionsJson) return;

		type Q = { correctIndex: number; explanation: string };
		let questions: Q[];
		try {
			questions = JSON.parse(questionsJson) as Q[];
		} catch {
			return;
		}

		questions.forEach((q, qi) => {
			const key = `${quizId}-${qi}`;
			const optionGroup = root.querySelector<HTMLElement>(`[data-quiz-options="${key}"]`);
			const labels = optionGroup
				? Array.from(optionGroup.querySelectorAll<HTMLLabelElement>('.quiz-option'))
				: [];
			const radios = root.querySelectorAll<HTMLInputElement>(`input[name="q-${quizId}-${qi}"]`);
			const feedback = root.querySelector<HTMLDivElement>(`[data-feedback="${key}"]`);
			const actions = root.querySelector<HTMLDivElement>(`[data-actions="${key}"]`);
			const resetBtn = root.querySelector<HTMLButtonElement>(`[data-reset="${key}"]`);

			function lock() {
				radios.forEach((r) => {
					r.disabled = true;
				});
				labels.forEach((l) => l.classList.add('is-locked'));
			}

			function unlock() {
				radios.forEach((r) => {
					r.disabled = false;
					r.checked = false;
				});
				labels.forEach((l) =>
					l.classList.remove('is-locked', 'is-correct', 'is-wrong', 'is-reveal'),
				);
				if (feedback) {
					feedback.hidden = true;
					feedback.textContent = '';
					feedback.className = 'quiz-feedback';
				}
				if (actions) actions.hidden = true;
			}

			radios.forEach((radio) => {
				radio.addEventListener('change', () => {
					if (!radio.checked || !feedback) return;
					const idx = parseInt(radio.value, 10);
					const ok = idx === q.correctIndex;

					labels.forEach((label, i) => {
						if (i === idx) {
							label.classList.add(ok ? 'is-correct' : 'is-wrong');
						}
						if (!ok && i === q.correctIndex) {
							label.classList.add('is-reveal');
						}
					});

					feedback.hidden = false;
					feedback.className = ok
						? 'quiz-feedback quiz-feedback--ok'
						: 'quiz-feedback quiz-feedback--bad';
					feedback.innerHTML = ok
						? `<strong>Richtig.</strong> ${(q as { explanation: string }).explanation}`
						: `<strong>Noch nicht passend.</strong> ${(q as { explanation: string }).explanation}`;

					lock();
					if (actions) actions.hidden = false;
				});
			});

			resetBtn?.addEventListener('click', unlock);
		});
	}

	function initAll() {
		document.querySelectorAll<HTMLElement>('[data-hack-quiz]').forEach(initOne);
	}

	initAll();
</script>
