---
/**
 * Bisheriges Startseiten-Hero (Matheunterricht, der ankommt …).
 * Aktivierung in `index.astro` über `HERO_VARIANT = 'legacy'`.
 */
interface Props {
	totalHacks: number;
	totalFields: number;
	totalQuizQuestions: number;
}

const { totalHacks, totalFields, totalQuizQuestions } = Astro.props;
---

<div class="hero-shell">
	<section class="hero" aria-labelledby="hero-title">
		<p class="hero__kicker">Wie man Mathe gut unterrichtet</p>
		<h1 id="hero-title" class="hero__title">
			<span class="hero__title-line1">Matheunterricht,</span><br aria-hidden="true" />
			<span class="hero__title-line2">
				der <em class="hero__accent-word">ankommt</em>.
			</span>
		</h1>
		<p class="hero__lead">
			<span class="hero__lead-line">Wirksame Hacks.</span>
			<span class="hero__lead-line">Von Lehrern für Lehrer.</span>
			<span class="hero__lead-line">Ohne Geschwurbel.</span>
		</p>
		<div class="hero__stats" role="list" aria-label="Übersicht">
			<div class="hero__stat-card" role="listitem">
				<strong class="hero__stat-num">{totalHacks}</strong>
				<span class="hero__stat-label">Hacks im Katalog</span>
			</div>
			<div class="hero__stat-card" role="listitem">
				<strong class="hero__stat-num">{totalFields}</strong>
				<span class="hero__stat-label">Themenfelder</span>
			</div>
			<div class="hero__stat-card" role="listitem">
				<strong class="hero__stat-num">{totalQuizQuestions}</strong>
				<span class="hero__stat-label">Quizfragen zum Selbstcheck</span>
			</div>
		</div>
	</section>
	<span class="hero-shell__sparkle" aria-hidden="true">✦</span>
</div>
