---
import BaseLayout from '../layouts/BaseLayout.astro';
import '@fontsource/unifrakturmaguntia';

const base = import.meta.env.BASE_URL;
const portraitSrc = `${base}images/autor-michael-glaubitz.png`;
---

<BaseLayout
	title="Dr. Michael Glaubitz — Über den Autor — Mathechismus.de"
	description="mathechismus.de von Dr. Michael Glaubitz: Bollwerk gegen pädagogischen Barock — praxisnahe Impulse statt didaktischem Leerlauf. Über 30 Jahre Erfahrung als Mathe- und Physiklehrer, Dozent, Fachleiter und Schulleiter."
	ogImage={portraitSrc}
>
	<article class="autor-page">
		<div class="autor-page__ambient" aria-hidden="true"></div>

		<header class="autor-page__head">
			<p class="autor-page__kicker">Über diese Seite</p>
			<h1 class="autor-page__title-fraktur">Dr. Michael Glaubitz</h1>
			<p class="autor-page__subtitle-fraktur">Kleiner und großer Mathechismus</p>
		</header>

		<figure class="autor-page__figure">
			<img
				src={portraitSrc}
				width="559"
				height="1024"
				sizes="(max-width: 480px) 92vw, 380px"
				loading="eager"
				decoding="async"
				fetchpriority="high"
				class="autor-page__img"
				alt="Porträt im Stil eines historischen Buchcovers: Dr. Michael Glaubitz mit weißem Kragen und einem aufgeschlagenen Buch; darüber und darunter der Name sowie die Zeile Kleiner und großer Mathechismus in weißer gebrochener Schrift auf schwarzem Grund."
			/>
			<figcaption class="autor-page__caption">
				
			</figcaption>
		</figure>

		<div class="autor-page__body">
			<p class="autor-page__lead">
				<strong>mathechismus.de</strong> ist das Projekt von <strong>Dr. Michael Glaubitz</strong> und versteht sich als Bollwerk gegen den pädagogischen Barock. Die hier versammelten Texte
				sind das Destillat aus jahrelanger Unterrichtspraxis, gefiltert durch eine gesunde Allergie gegen didaktischen Leerlauf. Das Prinzip ist simpel: Erst greifbar, dann präzise – ohne den
				esoterischen Beifang moderner Lehrpläne. Während dicke Handreichungen oft nur das Papier beschweren, auf dem sie stehen, finden Sie hier Impulse, die eine Schulstunde tatsächlich tragen.
				Ein Angebot für alle, die Substanz über Etiketten stellen und wissen, dass ein guter Satz mehr wert ist als ein zehnseitiges Kompetenzraster.
			</p>
			<p class="autor-page__lead">
				<strong>Dr. Glaubitz</strong> verfügt über 30-jährige berufliche Expertise als Mathematik- und Physiklehrer, als Universitätsdozent in der ersten Phase der Lehrerausbildung, als
				Fachleiter in der zweiten Phase der Lehrerausbildung, als schulfachlicher Koordinator sowie als Schulleiter.
			</p>
			<p class="autor-page__lead autor-page__more">
				Weiter zu den{' '}
				<a href={`${base}gebote/`}>10 Geboten für guten Unterricht</a>, den{' '}
				<a href={`${base}gebote-kompetenzorientiert/`}>10 Gegenboten für kompetenzorientierten Unterricht</a>, den{' '}
				<a href={`${base}thesen/`}>9,5 Thesen</a> oder zurück zum{' '}
				<a href={base}>Hack-Katalog</a>.
			</p>
		</div>
	</article>
</BaseLayout>
