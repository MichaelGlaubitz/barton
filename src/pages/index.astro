---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBookCover from '../components/HeroBookCover.astro';
import HeroLegacy from '../components/HeroLegacy.astro';
import { hackEmoji } from '../lib/hackCardIcons';
import { getCollection } from 'astro:content';

const hacks = (await getCollection('hacks')).sort(
	(a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);
const base = import.meta.env.BASE_URL;

/** Startseiten-Hero: `'book'` = Buchcover + Manifest · `'legacy'` = klassisches Hero (`HeroLegacy.astro`). */
const HERO_VARIANT: 'book' | 'legacy' = 'book';
const heroCoverSrc = `${base}images/autor-michael-glaubitz.png`;

interface FunctionGroup {
	key: string;
	chipLabel: string;
	title: string;
	description: string;
	ids: string[];
}

type LessonPhase = 'einstieg' | 'erarbeitung' | 'sicherung' | 'vertiefung' | 'reflexion';

interface PhaseMeta {
	key: LessonPhase;
	label: string;
}

const functionGroups: FunctionGroup[] = [
	{
		key: 'wissen',
		chipLabel: 'Wissen',
		title: 'Wissen sichern und abrufbar machen',
		description: 'Hacks für Erinnerung, Wiederkehr und langfristiges Behalten.',
		ids: [
			'abruf-ueben',
			'zeitlicher-abstand',
			'vorwissen-diagnose',
			'exit-tickets',
			'vergessenskurve-zeigen',
		],
	},
	{
		key: 'verstehen',
		chipLabel: 'Verstehen',
		title: 'Verstehen aufbauen und transferieren',
		description: 'Hacks für Konzeptaufbau, Vergleich und flexibles Anwenden.',
		ids: [
			'geloestes-beispiel',
			'beispielfamilien',
			'repraesentationen-wechseln',
			'vergleichsaufgaben',
			'aufgaben-stufen-oeffnen',
			'themen-vermischen',
			'selbsterklaerung-impuls',
		],
	},
	{
		key: 'ueben',
		chipLabel: 'Üben',
		title: 'Üben wirksamer steuern',
		description: 'Hacks für bessere Aufgabenwahl, Rückmeldung und Selbstkontrolle.',
		ids: [
			'zweckvolle-uebung',
			'feedback-handlungsnah',
			'leitfragen-selbstkontrolle',
			'whole-class-feedback',
		],
	},
	{
		key: 'diagnose',
		chipLabel: 'Diagnose',
		title: 'Diagnose und Unterrichtsentscheidungen',
		description: 'Hacks, mit denen du Unterricht in Echtzeit adaptierst.',
		ids: [
			'hinge-questions',
			'mini-whiteboards',
			'wartezeit-verlaengern',
			'acht-von-zehn',
			'routine-inhalt-zunaechst-vereinfachen',
			'routine-in-schritte-zerlegen',
			'routine-schritte-vormachen',
			'routine-jeden-schritt-einzeln-ueben',
			'routine-schritte-sichtbar-notieren',
			'routine-sinn-jeder-regel-begruenden',
			'routine-verstaendnis-aktiv-pruefen',
			'routine-cues-fuer-ablauf-nutzen',
		],
	},
	{
		key: 'plenum',
		chipLabel: 'Plenum',
		title: 'Besprechung und Unterrichtsgespräch',
		description:
			'Hacks für zielgerichtete Plenumsphasen — Auswahl, Sequenzierung und Diskussionsführung.',
		ids: [
			'diskussion-braucht-hochlevel-aufgabe',
			'denkzeit-vor-partnerarbeit',
			'lernziel-loesungswege-vorwegdenken',
			'arbeitsphasen-zielgerichtet-beobachten',
			'monitoring-chart-diskussion',
			'beitraege-fuers-plenum-auswaehlen',
			'praesentationen-sequenzieren',
			'schuelerideen-mit-lernziel-verbinden',
			'vertiefungsfragen-nachfassen',
			'front-load-beteiligung',
		],
	},
	{
		key: 'thinking',
		chipLabel: 'Denken',
		title: 'Denkendes Klassenzimmer',
		description:
			'Hacks für ein Klassenzimmer, in dem mathematisches Denken regelmäßig sichtbar wird — Aufgaben, Flächen, Gruppen.',
		ids: [
			'denkendes-klassenzimmer',
			'problemaufgaben-denken-zwingen',
			'vertikal-wechselnde-flaechen',
			'sichtbar-zufaellige-gruppen',
			'btc-stufe-eins-kleine-brueche',
		],
	},
	{
		key: 'fehler-denken',
		chipLabel: 'Fehler & Denken',
		title: 'Fehlerkultur und mathematisches Denken',
		description: 'Hacks für produktive Fehlerarbeit und hochwertige Diskussionen.',
		ids: [
			'fehler-lernen',
			'fehler-vorhersagen',
			'fragetechnik',
			'sprachsensibel-erklaeren',
			'niemals-ueberformen',
			'ich-weiss-nicht-produktiv',
		],
	},
	{
		key: 'entlastung',
		chipLabel: 'Entlastung',
		title: 'Kognitive Entlastung',
		description: 'Hacks, die unnötige Belastung reduzieren und Denkraum schaffen.',
		ids: ['kognitive-last'],
	},
];

const hacksById = new Map(hacks.map((hack) => [hack.id, hack]));

const phaseMeta: PhaseMeta[] = [
	{ key: 'einstieg', label: 'Einstieg' },
	{ key: 'erarbeitung', label: 'Erarbeitung' },
	{ key: 'sicherung', label: 'Sicherung' },
	{ key: 'vertiefung', label: 'Vertiefung' },
	{ key: 'reflexion', label: 'Reflexion des Gelernten' },
];

const phaseByHackId: Record<string, LessonPhase> = {
	'abruf-ueben': 'einstieg',
	'zeitlicher-abstand': 'sicherung',
	'vorwissen-diagnose': 'einstieg',
	'exit-tickets': 'sicherung',
	'vergessenskurve-zeigen': 'reflexion',
	'geloestes-beispiel': 'erarbeitung',
	'beispielfamilien': 'erarbeitung',
	'repraesentationen-wechseln': 'erarbeitung',
	'vergleichsaufgaben': 'vertiefung',
	'aufgaben-stufen-oeffnen': 'vertiefung',
	'themen-vermischen': 'sicherung',
	'selbsterklaerung-impuls': 'erarbeitung',
	'zweckvolle-uebung': 'vertiefung',
	'feedback-handlungsnah': 'reflexion',
	'leitfragen-selbstkontrolle': 'reflexion',
	'whole-class-feedback': 'sicherung',
	'hinge-questions': 'einstieg',
	'mini-whiteboards': 'erarbeitung',
	'wartezeit-verlaengern': 'erarbeitung',
	'acht-von-zehn': 'sicherung',
	'routine-inhalt-zunaechst-vereinfachen': 'einstieg',
	'routine-in-schritte-zerlegen': 'einstieg',
	'routine-schritte-vormachen': 'erarbeitung',
	'routine-jeden-schritt-einzeln-ueben': 'erarbeitung',
	'routine-schritte-sichtbar-notieren': 'sicherung',
	'routine-sinn-jeder-regel-begruenden': 'einstieg',
	'routine-verstaendnis-aktiv-pruefen': 'sicherung',
	'routine-cues-fuer-ablauf-nutzen': 'sicherung',
	'diskussion-braucht-hochlevel-aufgabe': 'vertiefung',
	'denkzeit-vor-partnerarbeit': 'erarbeitung',
	'lernziel-loesungswege-vorwegdenken': 'erarbeitung',
	'arbeitsphasen-zielgerichtet-beobachten': 'erarbeitung',
	'monitoring-chart-diskussion': 'sicherung',
	'beitraege-fuers-plenum-auswaehlen': 'sicherung',
	'praesentationen-sequenzieren': 'sicherung',
	'schuelerideen-mit-lernziel-verbinden': 'vertiefung',
	'vertiefungsfragen-nachfassen': 'vertiefung',
	'front-load-beteiligung': 'einstieg',
	'denkendes-klassenzimmer': 'erarbeitung',
	'problemaufgaben-denken-zwingen': 'vertiefung',
	'vertikal-wechselnde-flaechen': 'erarbeitung',
	'sichtbar-zufaellige-gruppen': 'erarbeitung',
	'btc-stufe-eins-kleine-brueche': 'einstieg',
	'fehler-lernen': 'reflexion',
	'fehler-vorhersagen': 'reflexion',
	'fragetechnik': 'erarbeitung',
	'sprachsensibel-erklaeren': 'erarbeitung',
	'kognitive-last': 'erarbeitung',
	'niemals-ueberformen': 'reflexion',
	'ich-weiss-nicht-produktiv': 'reflexion',
};

const phaseLabelByKey = Object.fromEntries(
	phaseMeta.map((phase) => [phase.key, phase.label]),
) as Record<LessonPhase, string>;

const unassignedPhaseIds = hacks
	.map((hack) => hack.id)
	.filter((id) => !(id in phaseByHackId));

if (unassignedPhaseIds.length > 0) {
	throw new Error(
		`Fehlende Unterrichtsphasen-Zuordnung für: ${unassignedPhaseIds.join(', ')}`,
	);
}

const totalHacks = hacks.length;
const totalFields = functionGroups.filter((g) =>
	g.ids.some((id) => hacksById.has(id)),
).length;
const totalQuizQuestions = hacks.reduce(
	(sum, hack) => sum + (hack.data.quiz?.length ?? 0),
	0,
);
const featuredIds = [
	'mini-whiteboards',
	'vertikal-wechselnde-flaechen',
	'monitoring-chart-diskussion',
];
const featuredHacks = featuredIds.map((id) => hacksById.get(id)).filter(Boolean);
---

<BaseLayout title="Mathechismus.de — Mathematikunterricht">
	{
		HERO_VARIANT === 'book' ? (
			<HeroBookCover
				totalHacks={totalHacks}
				totalFields={totalFields}
				totalQuizQuestions={totalQuizQuestions}
				coverSrc={heroCoverSrc}
			/>
		) : (
			<HeroLegacy
				totalHacks={totalHacks}
				totalFields={totalFields}
				totalQuizQuestions={totalQuizQuestions}
			/>
		)
	}

	<section class="spotlight" aria-labelledby="spotlight-title" data-spotlight-section>
		<div class="spotlight__copy">
			<p class="hero__kicker">Schnell reinfinden</p>
			<h2 id="spotlight-title">Drei Hacks für sofort</h2>
			<p>
				Weniger Theorie lesen, mehr Unterricht sehen: Diese Hacks verändern sichtbar,
				wie Lernende denken, zeigen, korrigieren und diskutieren.
			</p>
		</div>
		<div class="spotlight__cards">
			{
				featuredHacks.map((h, i) => {
					const phase = phaseByHackId[h.id];
					return (
						<a
							class="spotlight-card"
							href={`${base}hack/${h.id}/`}
							data-spotlight-card
							data-phase={phase}
							data-search={[
								h.data.title,
								h.data.summary,
								...h.data.tags,
								phaseLabelByKey[phase],
							]
								.join(' ')
								.toLowerCase()}
						>
							<span class="spotlight-card__num">{String(i + 1).padStart(2, '0')}</span>
							<span class="spotlight-card__emoji" aria-hidden="true">{hackEmoji(h.id)}</span>
							<strong>{h.data.title}</strong>
							<small>{h.data.tags.slice(0, 2).join(' · ')}</small>
						</a>
					);
				})
			}
		</div>
	</section>

	<div class="hack-catalog" data-hack-catalog>
		<div class="filter-shell">
			<div class="filter-bar" role="toolbar" aria-label="Hacks nach Hauptfunktion filtern">
				<button type="button" class="filter-chip is-active" data-filter="all" aria-pressed="true">
					Alle
				</button>
				{
					functionGroups.map((g) => (
						<button type="button" class="filter-chip" data-filter={g.key} aria-pressed="false">
							{g.chipLabel}
						</button>
					))
				}
			</div>
			<div class="phase-bar" role="toolbar" aria-label="Hacks nach Unterrichtsphase filtern">
				<span class="phase-bar__label">Unterrichtsphase:</span>
				<button
					type="button"
					class="filter-chip phase-chip is-active"
					data-phase-filter="all"
					aria-pressed="true"
				>
					Alle
				</button>
				{
					phaseMeta.map((phase) => (
						<button
							type="button"
							class="filter-chip phase-chip"
							data-phase-filter={phase.key}
							aria-pressed="false"
						>
							{phase.label}
						</button>
					))
				}
			</div>
			<div class="search-wrap">
				<label class="search-field">
					<span class="search-field__icon" aria-hidden="true">⌕</span>
					<input
						type="search"
						placeholder="Suche in Titel, Zusammenfassung, Tags…"
						aria-label="Hacks durchsuchen"
						data-hack-search
						autocomplete="off"
					/>
					<button type="button" class="search-field__clear" data-hack-search-clear aria-label="Suche löschen" hidden>
						×
					</button>
				</label>
				<p class="search-result" data-hack-search-result aria-live="polite" hidden></p>
			</div>
		</div>
		{
			functionGroups.map((group, gi) => {
				const groupedHacks = group.ids
					.map((id) => hacksById.get(id))
					.filter(Boolean);
				if (groupedHacks.length === 0) return null;
				const num = String(gi + 1).padStart(2, '0');
				return (
					<section class="function-group" data-group={group.key}>
						<div class="function-group__head">
							<span class="function-group__num" aria-hidden="true">{num}</span>
							<h2>{group.title}</h2>
						</div>
						<p class="function-group__desc">{group.description}</p>
						<div class="hack-grid">
							{groupedHacks.map((h) => {
								const phase = phaseByHackId[h.id];
								return (
									<a
										class="hack-card"
										href={`${base}hack/${h.id}/`}
										data-hack-card
										data-phase={phase}
										data-search={[
											h.data.title,
											h.data.summary,
											...h.data.tags,
										]
											.join(' ')
											.toLowerCase()}
									>
										<span class="hack-card__emoji-slot" aria-hidden="true">{hackEmoji(h.id)}</span>
										<span class="hack-card__meta">{phaseLabelByKey[phase]} · {h.data.tags[0]}</span>
										<h3>{h.data.title}</h3>
										<p>{h.data.summary}</p>
										<div class="tags">
											{h.data.tags.map((t) => (
												<span class="tag">{t}</span>
											))}
										</div>
									</a>
								);
							})}
						</div>
					</section>
				);
			})
		}
		<p class="empty-state" data-empty-state hidden>
			Keine Hacks gefunden. Passe die Filter, die Unterrichtsphase oder die Suche an.
		</p>
	</div>
	<script>
		(function () {
			const root = document.querySelector<HTMLElement>('[data-hack-catalog]');
			if (!root) return;
			const sections = Array.from(
				root.querySelectorAll<HTMLElement>('.function-group'),
			);
			const mainChips = Array.from(
				root.querySelectorAll<HTMLButtonElement>('.filter-bar [data-filter]'),
			);
			const phaseChips = Array.from(
				root.querySelectorAll<HTMLButtonElement>('.phase-bar [data-phase-filter]'),
			);
			const spotlightSection = document.querySelector<HTMLElement>('[data-spotlight-section]');
			const spotlightCards = spotlightSection
				? Array.from(
						spotlightSection.querySelectorAll<HTMLElement>('[data-spotlight-card]'),
					)
				: [];
			const searchInput = root.querySelector<HTMLInputElement>('[data-hack-search]');
			const clearBtn = root.querySelector<HTMLButtonElement>('[data-hack-search-clear]');
			const resultEl = root.querySelector<HTMLElement>('[data-hack-search-result]');
			const emptyEl = root.querySelector<HTMLElement>('[data-empty-state]');

			let activeFilter = 'all';
			let activePhase = 'all';
			let searchQuery = '';

			/** Diakritika nach NFD entfernen — ohne \p{Diacritic} (ältere WebViews / strikte parser) */
			function normalize(text: string) {
				try {
					return text
						.toLowerCase()
						.normalize('NFD')
						.replace(/[\u0300-\u036f]/g, '');
				} catch {
					return text.toLowerCase();
				}
			}

			function applyFilters() {
				const q = normalize(searchQuery.trim());
				let totalVisible = 0;

				let visibleSpotlight = 0;
				spotlightCards.forEach((card) => {
					const cardPhase = card.getAttribute('data-phase') ?? '';
					const matchesPhase =
						activePhase === 'all' || cardPhase === activePhase;
					if (!matchesPhase) {
						card.hidden = true;
						return;
					}
					if (!q) {
						card.hidden = false;
						visibleSpotlight++;
						return;
					}
					const haystack = normalize(card.getAttribute('data-search') ?? '');
					const isMatch = haystack.includes(q);
					card.hidden = !isMatch;
					if (isMatch) visibleSpotlight++;
				});
				if (spotlightSection) {
					spotlightSection.hidden = spotlightCards.length > 0 && visibleSpotlight === 0;
				}
				totalVisible += visibleSpotlight;

				sections.forEach((sec) => {
					const matchesFilter =
						activeFilter === 'all' ||
						sec.getAttribute('data-group') === activeFilter;
					if (!matchesFilter) {
						sec.hidden = true;
						return;
					}
					const cards = sec.querySelectorAll<HTMLElement>('[data-hack-card]');
					let visibleInSection = 0;
					cards.forEach((card) => {
						const cardPhase = card.getAttribute('data-phase') ?? '';
						const matchesPhase =
							activePhase === 'all' || cardPhase === activePhase;
						if (!matchesPhase) {
							card.hidden = true;
							return;
						}
						if (!q) {
							card.hidden = false;
							visibleInSection++;
							return;
						}
						const haystack = normalize(card.getAttribute('data-search') ?? '');
						const isMatch = haystack.includes(q);
						card.hidden = !isMatch;
						if (isMatch) visibleInSection++;
					});
					sec.hidden = visibleInSection === 0;
					totalVisible += visibleInSection;
				});

				if (resultEl) {
					if (q) {
						resultEl.hidden = false;
						resultEl.textContent =
							totalVisible === 0
								? `Keine Treffer für „${searchQuery.trim()}“.`
								: `${totalVisible} Treffer für „${searchQuery.trim()}“.`;
					} else {
						resultEl.hidden = true;
						resultEl.textContent = '';
					}
				}
				if (emptyEl) emptyEl.hidden = totalVisible !== 0;
				if (clearBtn) clearBtn.hidden = !q;
			}

			function setActiveMain(chip: HTMLButtonElement) {
				mainChips.forEach((c) => {
					const on = c === chip;
					c.classList.toggle('is-active', on);
					c.setAttribute('aria-pressed', on ? 'true' : 'false');
				});
				activeFilter = chip.getAttribute('data-filter') ?? 'all';
				applyFilters();
			}

			mainChips.forEach((chip) => {
				chip.addEventListener('click', () => setActiveMain(chip));
			});

			function setActivePhase(chip: HTMLButtonElement) {
				phaseChips.forEach((c) => {
					const on = c === chip;
					c.classList.toggle('is-active', on);
					c.setAttribute('aria-pressed', on ? 'true' : 'false');
				});
				activePhase = chip.getAttribute('data-phase-filter') ?? 'all';
				// Hauptfilter auf „Alle“: Phasenfilter soll alle Themenfelder durchsuchen.
				const allMain = mainChips.find((c) => c.getAttribute('data-filter') === 'all');
				if (allMain) {
					mainChips.forEach((c) => {
						const on = c === allMain;
						c.classList.toggle('is-active', on);
						c.setAttribute('aria-pressed', on ? 'true' : 'false');
					});
					activeFilter = 'all';
				}
				applyFilters();
			}

			phaseChips.forEach((chip) => {
				chip.addEventListener('click', () => setActivePhase(chip));
			});

			searchInput?.addEventListener('input', () => {
				searchQuery = searchInput.value;
				applyFilters();
			});

			clearBtn?.addEventListener('click', () => {
				if (!searchInput) return;
				searchInput.value = '';
				searchQuery = '';
				searchInput.focus();
				applyFilters();
			});

			searchInput?.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && searchInput.value) {
					searchInput.value = '';
					searchQuery = '';
					applyFilters();
				}
			});

			document.addEventListener('keydown', (e) => {
				if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
					e.preventDefault();
					searchInput?.focus();
				}
			});

			applyFilters();
		})();
	</script>
</BaseLayout>
