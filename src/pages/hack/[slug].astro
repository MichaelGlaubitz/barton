---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HackQuiz from '../../components/HackQuiz.astro';
import Giscus from '../../components/Giscus.astro';
import InlineEditButton from '../../components/InlineEditButton.astro';
import { hackEmoji } from '../../lib/hackCardIcons';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const hacks = await getCollection('hacks');
	return hacks.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${entry.data.title} — Mathechismus.de`} description={entry.data.summary}>
	<div class="reading-progress" data-reading-progress aria-hidden="true">
		<div class="reading-progress__bar" data-reading-progress-bar></div>
	</div>
	<article class="prose" data-prose-article>
		<p class="hack-back">
			<a href={`${base}`}>← Alle Hacks</a>
		</p>
		<div class="hack-detail-header">
			<span class="hack-detail-header__emoji" aria-hidden="true">{hackEmoji(entry.id)}</span>
			<h1>{entry.data.title}</h1>
			<p class="hack-detail-header__lead">{entry.data.summary}</p>
		</div>
		<div class="tags">
			{entry.data.tags.map((t) => (
				<span class="tag">{t}</span>
			))}
		</div>
		<Content />
		{entry.data.quiz && entry.data.quiz.length > 0 && (
			<HackQuiz questions={entry.data.quiz} quizId={entry.id.replace(/\//g, '-')} />
		)}
		<Giscus />
	</article>
	{import.meta.env.DEV && <InlineEditButton slug={entry.id} />}

	<script>
		(function () {
			const article = document.querySelector<HTMLElement>('[data-prose-article]');
			const bar = document.querySelector<HTMLElement>('[data-reading-progress-bar]');
			if (!article || !bar) return;
			let ticking = false;

			function update() {
				ticking = false;
				const rect = article.getBoundingClientRect();
				const total = Math.max(1, rect.height - window.innerHeight);
				const scrolled = Math.min(total, Math.max(0, -rect.top));
				const progress = Math.min(1, Math.max(0, scrolled / total));
				bar.style.transform = `scaleX(${progress})`;
			}

			window.addEventListener(
				'scroll',
				() => {
					if (!ticking) {
						requestAnimationFrame(update);
						ticking = true;
					}
				},
				{ passive: true },
			);
			window.addEventListener('resize', update);
			update();
		})();
	</script>
</BaseLayout>
