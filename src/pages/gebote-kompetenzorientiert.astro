---
export const prerender = true;

const base = import.meta.env.BASE_URL;
const target = `${base}10-gegenboten/`;
const canonicalHref =
	Astro.site != null ? new URL(target, Astro.site.origin).href : undefined;
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Weiterleitung — Mathechismus.de</title>
		{canonicalHref && <link rel="canonical" href={canonicalHref} />}
		<meta http-equiv="refresh" content={`0;url=${target}`} />
	</head>
	<body>
		<p>
			Diese Seite hat eine neue Adresse. <a href={target}>Weiter zu den 10 Gegenboten für kompetenzorientierten Unterricht</a>.
		</p>
	</body>
</html>
