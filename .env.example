# Optional: öffentliche Kontakt-E-Mail fürs Impressum / die Datenschutzerklärung (mailto-Link)
PUBLIC_CONTACT_EMAIL=

# Giscus (https://giscus.app — Werte aus der Konfiguration übernehmen)
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=Announcements
PUBLIC_GISCUS_CATEGORY_ID=
PUBLIC_GISCUS_MAPPING=pathname
PUBLIC_GISCUS_STRICT=0
PUBLIC_GISCUS_REACTIONS_ENABLED=1
PUBLIC_GISCUS_EMIT_METADATA=0
PUBLIC_GISCUS_INPUT_POSITION=bottom
PUBLIC_GISCUS_THEME=dark

# Domain/Hosting: Site-URL und Base-Pfad setzen
# Für mathechismus.de:
# PUBLIC_ASTRO_SITE=https://mathechismus.de
# PUBLIC_ASTRO_BASE=/
# Lokal: Zeilen auskommentieren oder BASE nur "/" belassen

PUBLIC_ASTRO_SITE=
PUBLIC_ASTRO_BASE=/

# Nur lokal (npm run dev): Text-Editor unter /admin-editor/ — mindestens 16 Zeichen
ADMIN_EDIT_TOKEN=
